#!/usr/bin/env bash
# pairp-nvim — bridge for Claude Code to control the parent Neovim instance.
# Requires $NVIM to be set (automatic when running inside Neovim terminal).

set -euo pipefail

if [ -z "${NVIM:-}" ]; then
  echo "Error: \$NVIM not set — not running inside Neovim" >&2
  exit 1
fi

NVIM_SERVER="$NVIM"

# Send a Lua expression to the parent Neovim via RPC and print the result.
nvim_lua() {
  local result
  if ! result=$(nvim --server "$NVIM_SERVER" --remote-expr "luaeval(\"$1\")" 2>&1); then
    echo "{\"ok\":false,\"error\":\"Neovim RPC failed: ${result//\"/\\\"}\"}"
    return 1
  fi
  echo "$result"
}

# Escape text for Lua single-quoted string inside luaeval("...").
lua_escape() {
  local s
  s=$(printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e "s/'/\\\\'/g")
  printf '%s' "$s" | sed -e 's/\\/\\\\/g'
}

# Ensure Pairp actions are available even if plugin startup order is delayed.
with_pairp_actions() {
  local inner_expr="$1"
  printf "(function() if _G.PairpActions == nil then local ok, actions = pcall(require, 'pairp.actions'); if ok and actions and actions.register then actions.register() end end; if _G.PairpActions == nil then return vim.json.encode({ ok = false, error = 'PairpActions unavailable' }) end; return %s end)()" "$inner_expr"
}

# Check whether the remote Neovim has vim.base64 helpers available.
has_remote_base64() {
  local out
  out=$(nvim --server "$NVIM_SERVER" --remote-expr "luaeval('(vim.base64 and vim.base64.decode) and 1 or 0')" 2>/dev/null || echo "0")
  [ "$out" = "1" ]
}

# Validate that a value is a non-negative integer.
require_int() {
  local label="$1" value="$2"
  if ! [[ "$value" =~ ^[0-9]+$ ]]; then
    echo "Error: expected integer for $label, got '$value'" >&2
    exit 1
  fi
}

# Open a file in the editor.
open_file() {
  local file="${1:?file required}"
  local line="${2:-}"
  local col="${3:-}"

  # Resolve to absolute path so Neovim opens the right file regardless of cwd
  local abs_path
  abs_path=$(cd "$(dirname "$file")" 2>/dev/null && printf '%s/%s' "$(pwd)" "$(basename "$file")") || abs_path="$file"

  local lua_line="nil"
  local lua_col="nil"
  if [ -n "$line" ]; then
    require_int "line" "$line"
    lua_line="$line"
  fi
  if [ -n "$col" ]; then
    require_int "col" "$col"
    lua_col="$col"
  fi

  local open_expr
  if has_remote_base64; then
    local b64
    b64=$(printf '%s' "$abs_path" | base64 | tr -d '\n')
    open_expr="vim.json.encode(PairpActions.open(vim.base64.decode('${b64}'), ${lua_line}, ${lua_col}))"
  else
    local escaped
    escaped=$(lua_escape "$abs_path")
    open_expr="vim.json.encode(PairpActions.open('${escaped}', ${lua_line}, ${lua_col}))"
  fi

  nvim_lua "$(with_pairp_actions "$open_expr")"
}

usage() {
  cat <<'USAGE'
pairp-nvim — control Neovim from Claude Code

Commands:
  open <file> [line] [col]    Open a file in the editor window
  buffers                     List open buffers
  help                        Show this help

When you edit files with your normal tools, Neovim will
automatically reload them in real-time (autoread + checktime).
USAGE
}

case "${1:-}" in
  open)
    shift
    open_file "${1:?file required}" "${2:-}" "${3:-}"
    ;;

  buffers)
    nvim_lua "$(with_pairp_actions "vim.json.encode(PairpActions.buffers())")"
    ;;

  help|--help|-h|"")
    usage
    ;;

  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
